# =============================================================================
# Audio Image Sync Studio — .gitignore
# =============================================================================

# ---- macOS system files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so

# ---- Python virtual environments ----
backend/.venv/
backend/venv/
.venv/
venv/
env/

# ---- Python environment / secrets ----
.env
.env.*
*.env

# ---- Backend uploads / outputs / temp (user-generated content) ----
backend/uploads/*
backend/outputs/*
backend/temp/*
# Keep the empty folder structure via .gitkeep
!backend/uploads/.gitkeep
!backend/outputs/.gitkeep
!backend/temp/.gitkeep

# ---- Frontend ----
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ---- App runtime logs and PIDs ----
logs/*
!logs/.gitkeep
.pids/*
!.pids/.gitkeep

# ---- IDE / editor files ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---- Misc ----
*.log
*.tmp
*.bak
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*TEMP_MPY*

# ---- User secrets / local integration configs ----
backend/data/notification_integrations.json

# ---- Desktop App ----
desktop/node_modules/
desktop/dist/
desktop/out/
desktop/release/
desktop/.vite/
desktop/*.log

# ---- Desktop Packaging ----
*.dmg
*.zip
*.exe
*.pkg

# ---- Backend Packaging ----
backend/build/
backend/dist/
backend/*.spec
