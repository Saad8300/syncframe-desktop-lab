{
  "name": "syncframe-desktop",
  "version": "1.0.1",
  "description": "Desktop Foundation for SyncFrame Studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:frontend": "cd ../frontend && npm run build",
    "build:mac": "npm run build:frontend && electron-builder --mac",
    "build:win": "npm run build:frontend && electron-builder --win",
    "build:dir": "npm run build:frontend && electron-builder --dir",
    "build:dir:win": "npm run build:frontend && electron-builder --win --dir",
    "pack": "npm run build:frontend && electron-builder"
  },
  "build": {
    "appId": "com.syncframe.studio",
    "productName": "SyncFrame Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
  "main.js",
  "preload.js",
  "updateService.js",
  "config.js",
  "package.json"
],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "resources/backend",
        "to": "backend"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "protocols": [
        {
          "name": "SyncFrame Studio Auth",
          "schemes": [
            "syncframe"
          ]
        }
      ]
    },
    "artifactName": "SyncFrame-Studio-${version}-${os}-${arch}.${ext}",
    "dmg": {
      "title": "SyncFrame Studio",
      "icon": "assets/icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.png",
      "protocols": [
        {
          "name": "SyncFrame Studio Auth",
          "schemes": [
            "syncframe"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
